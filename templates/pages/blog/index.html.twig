{% extends 'base.html.twig' %}

{% block title %}Blog{% if page > 1 %} - Page {{ page }}{% endif %} - EntryWeb{% endblock %}

{% block body %}
<div data-controller="scroll-animation blog-search" data-blog-search-url-value="{{ path('app_blog') }}">

    {# Hero #}
    <section class="page-hero">
        <div class="page-hero-inner">
            <h1 class="page-hero-title swiss-fade-up" data-scroll-animation-target="item">
                Conseils, <em>décryptages</em>,<br>retours terrain.
            </h1>
            <p class="page-hero-description swiss-fade-up" data-scroll-animation-target="item" data-delay="100">
                Tout ce qu'on apprend en créant des sites qui convertissent — partagé sans filtre, pour vous aider à réussir en ligne.
            </p>
        </div>
    </section>

    {# Recherche #}
    <section class="blog-search">
        <div class="blog-container">
            <form action="{{ path('app_blog') }}" method="get" class="blog-search-form swiss-fade-up" data-scroll-animation-target="item" data-delay="150" role="search" data-action="submit->blog-search#submit">
                <svg class="blog-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="search" name="q" value="{{ q }}" placeholder="Rechercher un article..." class="blog-search-input" aria-label="Rechercher un article" autocomplete="off" data-blog-search-target="input" data-action="input->blog-search#search">
                <button type="button" class="blog-search-clear" data-blog-search-target="clear" data-action="click->blog-search#clear" aria-label="Effacer la recherche" style="display: none;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>
                <button type="submit" class="blog-search-btn">Rechercher</button>
            </form>
        </div>
    </section>

    <div id="blog-results" data-blog-search-target="results">

    {% if q %}
        <div class="blog-container">
            <p class="blog-search-info">
                {{ total }} article{{ total > 1 ? 's' : '' }} pour «&nbsp;{{ q }}&nbsp;»
                — <a href="{{ path('app_blog') }}">voir tous les articles</a>
            </p>
        </div>
    {% endif %}

    {% if articles is empty %}
        <section class="blog-empty">
            <div class="blog-container">
                {% if q %}
                    <p>Aucun article ne correspond à votre recherche.</p>
                {% else %}
                    <p>Aucun article pour le moment. Revenez bientôt !</p>
                {% endif %}
            </div>
        </section>
    {% else %}

        {# Article vedette #}
        {% if featured %}
        <section class="blog-featured">
            <div class="blog-container">
                <a href="{{ path('app_blog_show', {slug: featured.slug}) }}" class="blog-featured-card swiss-fade-up" data-scroll-animation-target="item">
                    <div class="blog-featured-image">
                        {% if featured.coverImage %}
                            <img src="{{ featured.coverImage }}" alt="{{ featured.title }}">
                        {% else %}
                            <div class="blog-image-placeholder blog-image-placeholder--{{ featured.category|lower|replace({' ': '-', 'é': 'e', 'è': 'e', 'ê': 'e', 'ô': 'o'}) }}"></div>
                        {% endif %}
                        <span class="blog-badge blog-badge--featured">À la une</span>
                    </div>
                    <div class="blog-featured-body">
                        <span class="blog-category-badge">{{ featured.category }}</span>
                        <h2 class="blog-featured-title">{{ featured.title }}</h2>
                        <p class="blog-featured-excerpt">{{ featured.excerpt }}</p>
                        <div class="blog-meta">
                            <span class="blog-meta-date">{{ featured.publishedAt|date('d/m/Y') }}</span>
                            <span class="blog-meta-sep">·</span>
                            <span class="blog-meta-read">{{ featured.readTime }} min de lecture</span>
                        </div>
                        <span class="blog-link">Lire l'article →</span>
                    </div>
                </a>
            </div>
        </section>
        {% endif %}

        {# Grille d'articles #}
        {% if rest is not empty %}
        <section class="blog-grid-section">
            <div class="blog-container">
                <div class="blog-grid">
                    {% for article in rest %}
                    <article class="blog-card swiss-fade-up" data-scroll-animation-target="item" data-delay="{{ (loop.index0 % 3) * 100 }}">
                        <a href="{{ path('app_blog_show', {slug: article.slug}) }}" class="blog-card-image-link">
                            <div class="blog-card-image">
                                {% if article.coverImage %}
                                    <img src="{{ article.coverImage }}" alt="{{ article.title }}">
                                {% else %}
                                    <div class="blog-image-placeholder"></div>
                                {% endif %}
                            </div>
                        </a>
                        <div class="blog-card-body">
                            <span class="blog-category-badge">{{ article.category }}</span>
                            <h3 class="blog-card-title">
                                <a href="{{ path('app_blog_show', {slug: article.slug}) }}">{{ article.title }}</a>
                            </h3>
                            <p class="blog-card-excerpt">{{ article.excerpt|slice(0, 120) }}{% if article.excerpt|length > 120 %}...{% endif %}</p>
                            <div class="blog-meta">
                                <span class="blog-meta-date">{{ article.publishedAt|date('d/m/Y') }}</span>
                                <span class="blog-meta-sep">·</span>
                                <span class="blog-meta-read">{{ article.readTime }} min</span>
                            </div>
                        </div>
                    </article>
                    {% endfor %}
                </div>
            </div>
        </section>
        {% endif %}

        {# Pagination #}
        {% if totalPages > 1 %}
        <nav class="blog-pagination" aria-label="Pagination du blog">
            {% set extra = q ? {q: q} : {} %}
            {% if page > 1 %}
                <a href="{{ page - 1 == 1 ? path('app_blog', extra) : path('app_blog_page', {page: page - 1}|merge(extra)) }}" class="blog-pagination-link blog-pagination-link--arrow" aria-label="Page précédente">&larr;</a>
            {% endif %}
            {% for p in 1..totalPages %}
                {% if p == page %}
                    <span class="blog-pagination-link is-active" aria-current="page">{{ p }}</span>
                {% else %}
                    <a href="{{ p == 1 ? path('app_blog', extra) : path('app_blog_page', {page: p}|merge(extra)) }}" class="blog-pagination-link">{{ p }}</a>
                {% endif %}
            {% endfor %}
            {% if page < totalPages %}
                <a href="{{ path('app_blog_page', {page: page + 1}|merge(extra)) }}" class="blog-pagination-link blog-pagination-link--arrow" aria-label="Page suivante">&rarr;</a>
            {% endif %}
        </nav>
        {% endif %}

    {% endif %}

    </div>

    {# CTA newsletter / contact #}
    <section class="blog-cta swiss-fade-up" data-scroll-animation-target="item">
        <div class="blog-container">
            <div class="blog-cta-inner">
                <h2 class="blog-cta-title">Un projet en tête ?</h2>
                <p class="blog-cta-text">On répond sous 24h et le premier appel est gratuit.</p>
                <a href="{{ path('app_contact') }}" class="btn btn-primary">Démarrons ensemble</a>
            </div>
        </div>
    </section>

</div>
{% endblock %}
