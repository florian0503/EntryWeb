{% extends 'base.html.twig' %}

{% block title %}Réalisations — EntryWeb{% endblock %}
{% block meta_description %}Découvrez nos réalisations : sites vitrines, e-commerce et applications web créés pour des entrepreneurs et PME.{% endblock %}

{% block body %}
<div data-controller="scroll-animation">
    <section class="page-hero">
        <div class="page-hero-inner">
            <h1 class="page-hero-title swiss-fade-up" data-scroll-animation-target="item">Nos Réalisations</h1>
            <p class="page-hero-description swiss-fade-up" data-scroll-animation-target="item" data-delay="100">
                Des sites modernes qui convertissent.
            </p>
        </div>
    </section>

    <section class="realisations" data-controller="realisations-filter">
        <div class="realisations-container">
            <div class="realisations-filters swiss-fade-up" data-scroll-animation-target="item" data-delay="200">
                <button type="button" class="realisations-filter-btn is-active" data-filter="all" data-realisations-filter-target="filterBtn" data-action="click->realisations-filter#filter">Tous</button>
                {% for category in categories %}
                    <button type="button" class="realisations-filter-btn" data-filter="{{ category.slug }}" data-realisations-filter-target="filterBtn" data-action="click->realisations-filter#filter">{{ category.name }}</button>
                {% endfor %}
            </div>
        </div>

        <div class="realisations-showcase">
            {% for realisation in realisations %}
                <div class="realisation-band{% if loop.index is even %} realisation-band--alt{% endif %}" data-category="{{ realisation.category.slug }}" data-realisations-filter-target="card">
                    <div class="realisations-container">
                    <article class="realisation-feature{% if loop.index is even %} realisation-feature--reverse{% endif %} swiss-fade-up" data-scroll-animation-target="item">
                        <a href="{{ path('app_realisation_show', {id: realisation.id}) }}" class="realisation-feature-visual{% if realisation.hasDeviceMockup %} realisations-card-mockup{% endif %}">
                            {% if realisation.hasDeviceMockup %}
                                <div class="device-scene img-reveal">
                                    <div class="device-laptop">
                                        <div class="device-laptop-screen">
                                            <img src="{{ asset('uploads/realisations/' ~ realisation.imageName) }}" alt="{{ realisation.title }} — version ordinateur">
                                        </div>
                                        <div class="device-laptop-base"></div>
                                    </div>
                                    <div class="device-tablet">
                                        <img src="{{ asset('uploads/realisations/' ~ realisation.imageTabletName) }}" alt="{{ realisation.title }} — version tablette">
                                    </div>
                                    <div class="device-phone">
                                        <img src="{{ asset('uploads/realisations/' ~ realisation.imageMobileName) }}" alt="{{ realisation.title }} — version mobile">
                                    </div>
                                </div>
                            {% elseif realisation.imageName %}
                                <img src="{{ asset('uploads/realisations/' ~ realisation.imageName) }}" alt="{{ realisation.title }}" class="img-reveal">
                            {% else %}
                                <img src="https://via.placeholder.com/600x400?text={{ realisation.title|url_encode }}" alt="{{ realisation.title }}" class="img-reveal">
                            {% endif %}
                        </a>
                        <div class="realisation-feature-content">
                            <span class="realisations-card-tag">{{ realisation.category.name }}</span>
                            <h2 class="realisation-feature-title">{{ realisation.title }}</h2>
                            <p class="realisation-feature-desc">{{ realisation.description }}</p>
                            <a href="{{ path('app_realisation_show', {id: realisation.id}) }}" class="realisations-card-link">Voir la réalisation
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </a>
                        </div>
                    </article>
                    </div>
                </div>
            {% endfor %}

            <div class="realisations-container">
                <div class="realisations-empty" data-realisations-filter-target="emptyState" style="display: none;">
                    {% if realisations|length == 0 %}
                        <p>Nos réalisations arrivent bientôt.</p>
                    {% else %}
                        <p>Aucune réalisation dans cette catégorie pour le moment.</p>
                    {% endif %}
                </div>
            </div>
        </div>

        {% if realisations|length > 2 %}
            <div class="realisations-container">
                <div class="realisations-load-more">
                    <button type="button" class="btn-load-more is-hidden" data-realisations-filter-target="loadMoreBtn" data-action="click->realisations-filter#loadMore">
                        Voir plus
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
                    </button>
                </div>
            </div>
        {% endif %}
    </section>

    <section class="cta swiss-scale" data-scroll-animation-target="item">
        <div class="cta-container">
            <h2 class="cta-title">Prêt à lancer votre site web ?</h2>
            <p class="cta-description">
                Discutons de votre projet dès aujourd'hui. Devis gratuit, sans engagement.
            </p>
            <a href="{{ path('app_contact') }}" class="btn btn-formule btn-formule-primary">Démarrer mon projet</a>
        </div>
    </section>
</div>
{% endblock %}
