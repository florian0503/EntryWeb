{% extends 'base.html.twig' %}

{% block title %}Offres et Tarifs — EntryWeb{% endblock %}
{% block meta_description %}Création de site web professionnel jusqu'à 5 pages à 990€ HT. Hébergement, maintenance et sécurité inclus dès 69,90€ HT/mois.{% endblock %}

{% block body %}
<style>
/* ── Layout deux cards côte à côte ───────────────────────────── */
.pricing-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 940px;
    margin: 0 auto;
    padding: 0 1.5rem;
    align-items: stretch;
}
@media (max-width: 820px) {
    .pricing-row { grid-template-columns: 1fr; max-width: 480px; }
}

/* ── Card gauche — Création ──────────────────────────────────── */
.pricing-row .offer-card {
    border-radius: 16px !important;
    border: 1.5px solid #e5e7eb !important;
    box-shadow: none !important;
    background: #fff !important;
    transform: none !important;
}
.pricing-row .offer-card:hover {
    border-color: #0066ff !important;
    box-shadow: 0 4px 20px rgba(0,102,255,0.07) !important;
    transform: none !important;
}

/* ── Card droite — Abonnement : même DA que la gauche ─────────── */
.pricing-row .subscription-card {
    border-radius: 16px !important;
    border: 1.5px solid #e5e7eb !important;
    background: #fff !important;
    box-shadow: none !important;
    padding: 1.5rem !important;
    transform: none !important;
    position: static;
    overflow: visible;
}
.pricing-row .subscription-card::before,
.pricing-row .subscription-card::after { display: none !important; }
.pricing-row .subscription-card:hover {
    border-color: #0066ff !important;
    box-shadow: 0 4px 20px rgba(0,102,255,0.07) !important;
    transform: none !important;
}

/* Alignement gauche comme la card création */
.pricing-row .subscription-card .subscription-card-header {
    text-align: left !important;
}
.pricing-row .subscription-card .subscription-card-price {
    justify-content: flex-start !important;
}

/* Prix légèrement agrandi pour mieux respirer */
.pricing-row .subscription-card .subscription-amount {
    font-size: 2.5rem !important;
    letter-spacing: -0.02em;
    line-height: 1;
}

.pricing-row .sub-engagement {
    font-size: 0.75rem;
    color: #9ca3af;
    margin-top: 0.35rem;
}

/* Badge minimal */
.step-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: 2rem;
    padding: 0.28rem 0.8rem;
    margin-bottom: 1rem;
    color: #0052cc;
    background: #eef3ff;
}

/* ── Pourquoi nous ──────────────────────────────────────────── */
.why-us {
    padding: 5rem 1.5rem;
    background: #f9fafb;
}
.why-us-inner {
    max-width: 860px;
    margin: 0 auto;
}
.why-us-header {
    margin-bottom: 3rem;
}
.why-us-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #0066ff;
    margin: 0 0 0.75rem;
}
.why-us-title {
    font-size: 2rem;
    font-weight: 400;
    color: #111;
    margin: 0;
    line-height: 1.2;
}
.why-us-list {
    display: flex;
    flex-direction: column;
}
.why-us-row {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 0 2rem;
    padding: 2rem 0;
    border-top: 1px solid #e5e7eb;
    align-items: start;
}
.why-us-row:last-child {
    border-bottom: 1px solid #e5e7eb;
}
.why-us-num {
    font-size: 0.75rem;
    font-weight: 400;
    color: #d1d5db;
    letter-spacing: 0.05em;
    padding-top: 3px;
}
.why-us-content {}
.why-us-row-title {
    font-size: 1rem;
    font-weight: 400;
    color: #111;
    margin: 0 0 0.4rem;
}
.why-us-row-desc {
    font-size: 0.875rem;
    color: #6b7280;
    line-height: 1.7;
    margin: 0;
}
@media (max-width: 600px) {
    .why-us-row { grid-template-columns: 40px 1fr; gap: 0 1rem; }
    .why-us-title { font-size: 1.5rem; }
}

/* ── FAQ ─────────────────────────────────────────────────────── */
.faq-wrap {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.5rem;
}
.faq-item {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 0.75rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.faq-q {
    font-size: 0.95rem;
    font-weight: 600;
    color: #1a1a1a;
    margin: 0 0 0.5rem;
}
.faq-a {
    font-size: 0.875rem;
    color: #6b7280;
    margin: 0;
    line-height: 1.65;
}
</style>

<div data-controller="scroll-animation">

    {# ── Hero ── #}
    <section class="page-hero">
        <div class="page-hero-inner">
            <h1 class="page-hero-title title-reveal" data-controller="title-reveal">
                <span class="line-mask"><span class="line-inner">Un site web professionnel.</span></span>
                <span class="line-mask"><span class="line-inner">Une offre claire.</span></span>
            </h1>
            <p class="page-hero-description swiss-fade-up is-visible" data-scroll-animation-target="item">
                Pas de pack compliqué, pas de surprise. Un site clé en main jusqu'à 5 pages avec hébergement, maintenance et sécurité inclus dans votre abonnement.
            </p>
        </div>
    </section>

    <div class="tva-banner">
        <p>TVA non applicable, article 293B du CGI</p>
    </div>

    {# ── Offre + Abonnement côte à côte ── #}
    <section class="offers-pricing">
        <div class="pricing-row">

            {# Card gauche — Création site #}
            <div class="offer-card swiss-fade-up" data-scroll-animation-target="item" data-delay="0">
                <div class="offer-card-header">
                    <span class="step-badge">Création</span>
                    <h2 class="offer-card-title">Site web professionnel</h2>
                    <p class="offer-card-subtitle">Jusqu'à 5 pages · Design sur mesure · Livraison 5 semaines</p>
                    <div class="offer-card-price">
                        <span class="price-amount">990€<sup>HT</sup></span>
                        <span class="price-type">frais de mise en service (une seule fois)</span>
                    </div>
                </div>
                <div class="offer-card-body">
                    <ul class="offer-features">
                        <li><span class="offer-check"></span>Jusqu'à 5 pages personnalisées</li>
                        <li><span class="offer-check"></span>Design moderne sur mesure</li>
                        <li><span class="offer-check"></span>Site 100% responsive</li>
                        <li><span class="offer-check"></span>Blog intégré + espace admin</li>
                        <li><span class="offer-check"></span>Structure SEO optimisée</li>
                        <li><span class="offer-check"></span>Formulaire de contact</li>
                        <li><span class="offer-check"></span>Galerie photos / vidéos</li>
                        <li><span class="offer-check"></span>Animations fluides</li>
                        <li><span class="offer-check"></span>Intégration Google Maps</li>
                        <li><span class="offer-check"></span>Réseaux sociaux intégrés</li>
                        <li><span class="offer-check"></span>Technologie robuste &amp; sécurisée</li>
                        <li><span class="offer-check"></span>Livraison sous 5 semaines</li>
                    </ul>
                </div>
            </div>

            {# Card droite — Abonnement #}
            <div class="subscription-card swiss-fade-up" data-scroll-animation-target="item" data-delay="100">
                <div class="subscription-card-header">
                    <span class="step-badge">Mensuel</span>
                    <h3 class="subscription-card-title">Abonnement tout inclus</h3>
                    <div class="subscription-card-price">
                        <span class="subscription-amount">69,90€<sup>HT</sup></span>
                        <span class="subscription-period">/mois</span>
                    </div>
                    <div class="sub-engagement">Engagement 24 mois</div>
                </div>
                <div class="subscription-card-body">
                    <ul class="subscription-features">
                        <li class="included"><span class="sub-check"></span>Hébergement haute performance</li>
                        <li class="included"><span class="sub-check"></span>Nom de domaine (.fr ou .com)</li>
                        <li class="included"><span class="sub-check"></span>Certificat SSL (HTTPS)</li>
                        <li class="included"><span class="sub-check"></span>Mises à jour de sécurité</li>
                        <li class="included"><span class="sub-check"></span>Sauvegardes automatiques</li>
                        <li class="included"><span class="sub-check"></span>Support email prioritaire</li>
                        <li class="included"><span class="sub-check"></span>1h de maintenance/mois</li>
                        <li class="included"><span class="sub-check"></span>Monitoring continu 24/7</li>
                    </ul>
                    <p class="subscription-upgrade">Options : email pro · maintenance supplémentaire</p>
                </div>
            </div>

        </div>

        {# CTA sous les deux cards #}
        <div class="swiss-fade-up" data-scroll-animation-target="item" style="text-align:center;margin-top:2rem;">
            <a href="{{ path('app_contact', {'offer': 'site-web'}) }}" class="btn-offer btn-offer-primary" style="display:inline-block;width:auto;padding:14px 40px;">Démarrer mon projet</a>
            <p style="font-size:0.75rem;color:#9ca3af;margin-top:0.65rem;">Échange gratuit · Sans engagement initial · Réponse sous 24h</p>
        </div>

    </section>

    {# ── Pourquoi nous choisir ── #}
    <section class="why-us">
        <div class="why-us-inner">
            <div class="why-us-header swiss-fade-up" data-scroll-animation-target="item">
                <p class="why-us-label">Nos engagements</p>
                <h2 class="why-us-title">Pourquoi choisir EntryWeb ?</h2>
            </div>
            <div class="why-us-list">
                <div class="why-us-row swiss-fade-up" data-scroll-animation-target="item" data-delay="0">
                    <span class="why-us-num">01</span>
                    <div class="why-us-content">
                        <p class="why-us-row-title">100% codé sur mesure</p>
                        <p class="why-us-row-desc">Pas de WordPress, pas de template acheté en ligne. Votre site est développé de A à Z — performances optimales, sécurité renforcée et une identité vraiment unique.</p>
                    </div>
                </div>
                <div class="why-us-row swiss-fade-up" data-scroll-animation-target="item" data-delay="50">
                    <span class="why-us-num">02</span>
                    <div class="why-us-content">
                        <p class="why-us-row-title">Votre propriété après 24 mois</p>
                        <p class="why-us-row-desc">Au bout de 24 mensualités, le code source vous appartient intégralement. Vous pouvez l'héberger où vous voulez et le faire évoluer librement, sans dépendre de nous.</p>
                    </div>
                </div>
                <div class="why-us-row swiss-fade-up" data-scroll-animation-target="item" data-delay="100">
                    <span class="why-us-num">03</span>
                    <div class="why-us-content">
                        <p class="why-us-row-title">Interface d'administration</p>
                        <p class="why-us-row-desc">Gérez vos contenus en toute autonomie : textes, images, articles de blog… sans avoir besoin de nous contacter pour chaque modification.</p>
                    </div>
                </div>
                <div class="why-us-row swiss-fade-up" data-scroll-animation-target="item" data-delay="150">
                    <span class="why-us-num">04</span>
                    <div class="why-us-content">
                        <p class="why-us-row-title">Prix concurrentiels</p>
                        <p class="why-us-row-desc">990€ HT de mise en service, là où la plupart des agences facturent 3 à 5× plus pour un résultat équivalent. Pas de mauvaise surprise, pas de frais cachés.</p>
                    </div>
                </div>
                <div class="why-us-row swiss-fade-up" data-scroll-animation-target="item" data-delay="200">
                    <span class="why-us-num">05</span>
                    <div class="why-us-content">
                        <p class="why-us-row-title">Livré en 30 jours ouvrés</p>
                        <p class="why-us-row-desc">On s'engage sur un délai réaliste et tenu. Votre site est en ligne en moins de 6 semaines calendaires après le lancement du projet.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ── FAQ ── #}
    <section style="padding:3rem 0;background:#fff;">
        <div class="faq-wrap">
            <div class="subscriptions-header swiss-fade-up" data-scroll-animation-target="item" style="margin-bottom:2rem;">
                <h2 class="subscriptions-title">Questions fréquentes</h2>
            </div>
            <div class="faq-item swiss-fade-up" data-scroll-animation-target="item" data-delay="0">
                <p class="faq-q">Pourquoi une seule offre ?</p>
                <p class="faq-a">Parce qu'elle répond à 95% des besoins des entrepreneurs et PME. Moins de choix, plus de clarté — vous savez exactement ce que vous obtenez.</p>
            </div>
            <div class="faq-item swiss-fade-up" data-scroll-animation-target="item" data-delay="50">
                <p class="faq-q">L'abonnement est-il obligatoire ?</p>
                <p class="faq-a">Oui. Il couvre l'hébergement, la sécurité et la maintenance de votre site. C'est un service continu qui garantit que votre site reste en ligne, rapide et sécurisé.</p>
            </div>
            <div class="faq-item swiss-fade-up" data-scroll-animation-target="item" data-delay="100">
                <p class="faq-q">Que se passe-t-il après 24 mois ?</p>
                <p class="faq-a">L'abonnement continue mensuellement sans engagement minimum. Vous pouvez résilier avec préavis d'un mois. Le site reste en ligne tant que l'abonnement est actif.</p>
            </div>
            <div class="faq-item swiss-fade-up" data-scroll-animation-target="item" data-delay="150">
                <p class="faq-q">J'ai besoin de plus de 5 pages ou d'une boutique en ligne ?</p>
                <p class="faq-a">Contactez-nous directement pour un devis sur-mesure. Refonte, e-commerce, fonctionnalités spécifiques — on étudie chaque projet au cas par cas.</p>
            </div>
        </div>
    </section>

    {# ── Conditions légales ── #}
    <section class="offers-comparison" style="padding-top:2rem;background:#f9fafb;">
        <div class="offers-comparison-container">
            <div class="legal-terms-summary swiss-fade-up" data-scroll-animation-target="item">
                <p><strong>1. Engagement :</strong> Le présent contrat est conclu pour une durée ferme de 24 mois. Le Client reconnaît que l'abonnement mensuel de maintenance et d'hébergement est indissociable de la création du site et s'engage à le régler par prélèvement automatique.</p>
                <p><strong>2. Résiliation :</strong> En cas de défaut de paiement ou de résiliation anticipée par le Client avant la fin des 24 mois, la totalité des mensualités restantes devient immédiatement exigible. Une indemnité forfaitaire de 150€ sera appliquée pour frais de gestion de dossier contentieux.</p>
                <p><strong>3. Propriété :</strong> Le Prestataire conserve la propriété intellectuelle et technique intégrale du site internet (code source, design, base de données) jusqu'au paiement complet de la 24ème mensualité. En cas d'impayé supérieur à 7 jours, l'accès au site sera suspendu sans préavis.</p>
            </div>
        </div>
    </section>

    {# ── CTA ── #}
    <section class="cta">
        <div class="cta-container">
            <h2 class="cta-title swiss-fade-up" data-scroll-animation-target="item">Prêt à lancer votre projet ?</h2>
            <p class="cta-description swiss-fade-up" data-scroll-animation-target="item">Premier échange gratuit et sans engagement. On répond sous 24h.</p>
            <a href="{{ path('app_contact') }}" class="btn btn-formule btn-formule-primary swiss-fade-up" data-scroll-animation-target="item">Prendre rendez-vous</a>
        </div>
    </section>

</div>
{% endblock %}
